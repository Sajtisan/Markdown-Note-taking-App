<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:MarkdownNotesClient"
             x:Class="MarkdownNotesClient.App"
             RequestedThemeVariant="Default">
             <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <FontFamily x:Key="NovaRoundFont">avares://MarkdownNotesClient/Assets/Fonts#Nova Round</FontFamily>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://MarkdownNotesClient/Controls/GlassWindow.axaml" />
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource NovaRoundFont}" />
        </Style>
        
        <Style Selector="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource NovaRoundFont}" />
        </Style>
        
        <Style Selector="Button">
            <Setter Property="FontFamily" Value="{StaticResource NovaRoundFont}" />
        </Style>
    </Application.Styles>
</Application>